<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>All Products</h1>

<table border="1">

<tr>
<th>Name</th>
<th>Category</th>
<th>Price</th>
<th>Stock</th>
</tr>

<% products.forEach(product=>{ %>

<tr>

<td>
<%= product.productName %>
</td>

<td>
<%= product.category %>
</td>

<td>
₹ <%= product.price %>
</td>

<td>
<%= product.stock %>
</td>

</tr>

<% }) %>

</table>
</body>
</html>