<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Instagram Profile</title>

<style>

body{
    font-family: Arial;
    background:#f5f5f5;
}

.card{

    width:350px;
    margin:50px auto;
    background:white;
    padding:20px;
    border-radius:15px;
    box-shadow:0px 5px 20px rgba(0,0,0,.2);
    text-align:center;

}

img{

    width:150px;
    height:150px;
    border-radius:50%;
    object-fit:cover;

}

button{

    padding:10px 20px;
    margin:10px;
    border:none;
    border-radius:10px;
    cursor:pointer;

}

.follow{
    background:#0095f6;
    color:white;
}

.message{
    background:#ddd;
}

</style>

</head>
<body>

<div class="card">

    <img src="<%= user.profilePic %>" alt="Profile">

    <h2><%= user.name %></h2>

    <h3>@<%= user.username %></h3>

    <p><%= user.bio %></p>

    <h4>
        Followers :
        <%= user.followers %>
    </h4>

    <h4>
        Following :
        <%= user.following %>
    </h4>

    <button class="follow">
        Follow
    </button>

    <button class="message">
        Message
    </button>

</div>

</body>
</html>