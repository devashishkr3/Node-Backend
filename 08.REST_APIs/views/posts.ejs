<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Posts</title>
</head>
<body>
    <h1>Quora Posts</h1>
    <% for(post of posts){ %>
        <div class="post">
            <h3 class="username">username : @<%= post.username %></h3>
            <p class="content">Content: <%= post.content %></p>
            <a href="http://localhost:8080/posts/<%=post.username%>">Show post in detail.</a>
        </div>
    <% } %>
</body>
</html>